# Signer used by the EVM Write capability during LOCAL SIMULATION only.
# In production the Chainlink DON signs the on-chain flag write; this key is
# used solely by `cre workflow simulate ... --broadcast` so you can test the
# full read -> report -> write path against Base Sepolia from your machine.
CRE_ETH_PRIVATE_KEY=0xyour_private_key_here

# Default CLI target profile: local-simulation | staging-settings | production-settings
CRE_TARGET=local-simulation
