#!/bin/bash
# WrapSynth LP Node CLI wrapper

cd "$(dirname "$0")"

# Load environment variables from .env if it exists
if [ -f ".env" ]; then
    export $(grep -v '^#' .env | xargs)
fi

# Check if binary exists
if [ ! -f "target/release/wrapsynth-lp-node" ]; then
    echo "Binary not found. Building..."
    cargo build --release
fi

# Run the CLI
./target/release/wrapsynth-lp-node "$@"
