# Deployment Configuration

# Private key for deployment and oracle (DO NOT commit the actual .env file!)
# This account will be the deployer and the oracle
PRIVATE_KEY=your_private_key_here

# Unichain Testnet RPC URL
UNICHAIN_RPC_URL=https://sepolia.unichain.org

# Gnosis Mainnet RPC URL
GNOSIS_RPC_URL=https://rpc.gnosischain.com

# Etherscan API Key (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Gnosisscan API Key (for Gnosis contract verification)
GNOSISSCAN_API_KEY=your_gnosisscan_api_key_here

# Unichain Testnet Contract Addresses
WSTETH_ADDRESS=0xc02fe7317d4eb8753a02c35fe019786854a92001
PYTH_ADDRESS=0x2880aB155794e7179c9eE2e38200202908C17B43

# Gnosis Mainnet Contract Addresses
# wstETH on Gnosis: https://gnosisscan.io/token/0x6C76971f98945AE98dD7d4DFcA8711ebea946eA6
# Pyth Oracle on Gnosis: https://docs.pyth.network/price-feeds/contract-addresses/evm
GNOSIS_WSTETH_ADDRESS=0x6C76971f98945AE98dD7d4DFcA8711ebea946eA6
GNOSIS_PYTH_ADDRESS=0x2880aB155794e7179c9eE2e38200202908C17B43

# Oracle configuration
# The deployer (PRIVATE_KEY above) is automatically set as the oracle

# Monero RPC URL (for oracle to fetch blockchain data)
# For production, run your own monerod node
MONERO_RPC_URL=http://xmr.privex.io:18081

# Oracle polling interval in seconds
POLL_INTERVAL_SECS=20
