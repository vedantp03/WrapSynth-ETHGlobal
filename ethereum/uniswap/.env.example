# ── Wallet ───────────────────────────────────────────────────────────────────
PRIVATE_KEY=0x...
WALLET_ADDRESS=

# ── RPC ───────────────────────────────────────────────────────────────────────
BASE_SEPOLIA_RPC=https://sepolia.base.org

# ── API Keys ──────────────────────────────────────────────────────────────────
BASESCAN_API_KEY=
UNISWAP_API_KEY=

# ── Contract addresses (filled after Deploy.s.sol runs) ───────────────────────
TWSXMR_ADDRESS=

# ── LP funding (FundPool.s.sol) — amounts in RAW base units ───────────────────
# wsXMR has 8 decimals (150000 = 0.0015 wsXMR); WETH has 18 (315000000000000 = 0.000315).
# The wsXMR/WETH pool + token addresses live in script/PoolConfig.sol.
WSXMR_AMOUNT=150000
WETH_AMOUNT=315000000000000
# Set to true to auto-wrap native ETH into WETH if your WETH balance is short.
WRAP_ETH=false

# ── Proxy server ──────────────────────────────────────────────────────────────
PORT=3002
